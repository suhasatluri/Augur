# ── Augur Environment Variables ──
# Copy to .env and fill in your values.
# See CONTRIBUTING.md for setup instructions.

# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host.neon.tech/augur?sslmode=require

# Augur API authentication (comma-separated, defaults to augur-dev-key)
AUGUR_API_KEYS=dev-key-1,dev-key-2

# Perplexity Sonar (real-time financial news)
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Cloudflare R2 — optional for local dev
# Seed cache falls back to Neon when R2 is not configured.
STORAGE_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=your_r2_access_key
STORAGE_SECRET_KEY=your_r2_secret_key

# Grafana Cloud — optional for local dev
# Logs and metrics fall back to console when not configured.
GRAFANA_LOKI_URL=https://logs-prod-xxx.grafana.net
GRAFANA_LOKI_USER=your_loki_user_id
GRAFANA_API_KEY=your_grafana_api_key
ENVIRONMENT=production
